{
  "name": "@mammothb/pi-web",
  "version": "6.0.1",
  "description": "A pi extension that adds WebFetch and WebSearch tools for fetching and searching web content",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "bin": {
    "searxng": "./bin/searxng"
  },
  "files": [
    "index.ts",
    "src",
    "searxng",
    "bin"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@mammothb/pi-shared": "workspace:*",
    "htmlparser2": "catalog:",
    "turndown": "catalog:"
  },
  "devDependencies": {
    "@types/turndown": "catalog:"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  }
}
