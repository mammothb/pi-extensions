{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "useBlockStatements": "error"
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!coverage",
      "!packages/*/dist",
      "!packages/*/coverage",
      "!node_modules"
    ]
  },
  "overrides": [
    {
      "includes": [
        "test/**",
        "packages/*/test/**",
        "packages/*/evals/**",
        "*.test.ts",
        "*.spec.ts",
        "packages/pi-memory/src/before-compact.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  },
  "json": {
    "formatter": {
      "indentStyle": "space"
    }
  }
}
